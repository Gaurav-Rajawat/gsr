    {
      "cell_type": "code",
      "source": [
        "cat_features = ['is_male', 'is_smoker', 'region_northwest', 'region_southeast'\n",
        "                , 'region_southwest', 'bmi_catogory_normal', 'bmi_catogory_overweight', 'bmi_catogory_obese']"
